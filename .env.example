# Copy to `.env` (this file is ignored by git) and fill in your local keys.

# Optional: isolate vibe-tree config per worktree to avoid cross-branch config.json conflicts.
# scripts/dev.sh / scripts/web.sh start daemon from `backend/`, so this path is relative to `backend/`.
XDG_CONFIG_HOME=./tmp/xdg-config


# Anthropic (used by experts: master / claudecode)
ANTHROPIC_API_KEY=your_key_here

# OpenAI (used by expert: codex)
OPENAI_API_KEY=your_key_here
